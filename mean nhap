window.filterProducts = function(category, event, pageSectionId) {
    const grid = document.getElementById('product-grid');
    grid.innerHTML = ""; // Xóa sản phẩm cũ

    // Nếu chọn 'all', hiển thị tất cả sản phẩm của nam
    if (category === 'all') {
        const maleCats = ['tshirts', 'pants', 'jackets'];
        maleCats.forEach(cat => {
            window.storeData[cat].forEach(item => {
                createItem(cat, item.name, item.price, item.img, grid);
            });
        });
    } else {
        // Nếu chọn danh mục cụ thể (ví dụ 'ao-thun' - lưu ý map key của bạn)
        // Nếu category là 'ao-thun', hãy map nó với key 'tshirts' trong storeData
        const keyMap = { 'ao-thun': 'tshirts', 'quan-jean': 'pants', 'ao-khoac-jean': 'jackets' };
        const dataKey = keyMap[category];
        
        if (window.storeData[dataKey]) {
            window.storeData[dataKey].forEach(item => {
                createItem(category, item.name, item.price, item.img, grid);
            });
        }
    }
};

// Thêm hàm này vào cuối file mean.js
window.showToast = function(message) {
    // 1. Tạo phần tử thông báo
    const toast = document.createElement('div');
    toast.textContent = message;
    // 3. Đưa vào màn hình
    document.body.appendChild(toast);

    // 4. Tự xóa sau 2 giây
    setTimeout(() => {
        toast.remove();
    }, 2000);
};

window.addToCart = function(event) {
    if (event) event.preventDefault();

    // --- BƯỚC MỚI: KIỂM TRA ĐĂNG NHẬP ---
    // Giả sử bạn lưu trạng thái đăng nhập là 'true' hoặc 'false' trong localStorage
    const isLoggedIn = localStorage.getItem('isLoggedIn') === 'true';

    if (!isLoggedIn) {
        // Nếu chưa đăng nhập, thông báo và dừng lại
        alert("Bạn cần đăng nhập để thêm sản phẩm vào giỏ hàng!");
        
        // Tùy chọn: Chuyển hướng sang trang đăng nhập
        window.showPage('dang-nhap');
        return; // Dừng hàm tại đây, không thực hiện tiếp
    }
    // ------------------------------------

    // Nếu đã đăng nhập, thực hiện tiếp logic cũ của bạn
    const name = document.getElementById('detail-name').innerText;
    const price = document.getElementById('detail-price').innerText;
    const img = document.getElementById('detail-img').src;
    const qty = parseInt(document.getElementById('detail-qty').innerText);

    const existingItem = window.cart.find(item => item.name === name);
    if (existingItem) {
        existingItem.qty += qty;
    } else {
        window.cart.push({ name, price, img, qty });
    }
    
    localStorage.setItem('myCart', JSON.stringify(window.cart));
    window.updateCartCount();
    window.showToast("Đã thêm " + name + " vào giỏ hàng!");
    if(typeof window.closeDetail === 'function') window.closeDetail();
};

window.updateCartCount = function() {
    const cartCountElement = document.getElementById('cart-count');
    if (cartCountElement) {
        const totalItems = window.cart.reduce((sum, item) => sum + item.qty, 0);
        cartCountElement.innerText = totalItems;
    }
};

// Hàm Thêm vào giỏ (Phiên bản mới)
window.addToCart = function() {
    // 1. Lấy thông tin từ khung chi tiết (detail-...)
    const name = document.getElementById('detail-name').innerText;
    const price = document.getElementById('detail-price').innerText;
    const img = document.getElementById('detail-img').src;
    const qty = parseInt(document.getElementById('detail-qty').innerText);

    // 2. Thêm vào mảng giỏ hàng toàn cục
    window.cart.push({ name, price, img, qty });
    
    // 3. Lưu vào localStorage để không mất giỏ hàng khi F5
    localStorage.setItem('myCart', JSON.stringify(window.cart));
    
    // 4. Cập nhật icon giỏ hàng trên menu
    window.updateCartCount();
    
    // 5. Thông báo cho người dùng (thay vì alert)
    window.showToast("Đã thêm " + name + " vào giỏ hàng!");
    
    // 6. Đóng modal sau khi xong
    window.closeDetail();
};

